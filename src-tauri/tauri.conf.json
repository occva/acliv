{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACLIV",
  "version": "1.0.13",
  "identifier": "com.aicli.historyviewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ACLIV",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1MzZBNDAyOUI0RUQ4RjIKUldUeTJFNmJBcVEyaGFFN0hENm5WU3lhS3Z6K0lWOXg0K00yWkpYN1JpbDJmTFdEdWtPSkt3cXIK",
      "endpoints": [
        "https://github.com/occva/acliv/releases/latest/download/latest.json"
      ]
    }
  }
}
