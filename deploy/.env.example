# Host bind address for published port
BIND_HOST=0.0.0.0

# Web server listen port
AICHV_PORT=17860

# Required auth token for all protected APIs
# Generate with: openssl rand -hex 32
AICHV_TOKEN=

# Host home directory that stores CLI history folders (.claude/.codex/.gemini/...)
HOST_HOME=

# Mount target inside container. Usually no need to change.
CONTAINER_HOME=/host-home

# Timezone
TZ=Asia/Shanghai
